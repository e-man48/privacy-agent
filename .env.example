# Kopiere diese Datei nach ".env" und passe sie an.
# Nur der Cloud-Notfall braucht einen Schluessel -- der lokale Betrieb laeuft ohne.

# Anthropic / Claude (nur fuer den Cloud-Notfall, nach Einwilligung)
ANTHROPIC_API_KEY=

# Optional: Modelle ueberschreiben
# LOCAL_MODEL=qwen2.5:7b
# EMBED_MODEL=nomic-embed-text
# CLOUD_MODEL=claude-haiku-4-5-20251001
# CLOUD_MODEL_STRONG=claude-opus-4-8

# Optional: semantisches Gedaechtnis feinjustieren
# SEMANTIC_DUP_THRESHOLD=0.82   # ab hier gelten Eintraege als Duplikat/Synonym
# SEMANTIC_MIN_SIM=0.45         # Mindest-Aehnlichkeit fuer Suchtreffer

# Optional: Messenger-Connector -- Agent ueber einen Messenger erreichbar machen
# CONNECTOR=matrix                       # none | matrix
# MATRIX_HOMESERVER=https://matrix.dein-server.de
# MATRIX_USER=@agent:dein-server.de
# MATRIX_PASSWORD=                        # ODER MATRIX_ACCESS_TOKEN setzen
# MATRIX_ACCESS_TOKEN=
# MATRIX_DEVICE_NAME=PrivacyAgent
# WICHTIG: nur diese Nutzer duerfen den Agenten steuern (kommagetrennt)!
# MATRIX_ALLOWED_USERS=@ich:dein-server.de,@partner:dein-server.de
# Optional: nur diese Nutzer duerfen die Cloud freigeben (leer = alle erlaubten).
# MATRIX_ADMIN_USERS=@ich:dein-server.de

# Optional: Code-Sandbox (Werkzeug run_python)
# SANDBOX_BACKEND=auto          # auto | docker | subprocess
# SANDBOX_IMAGE=python:3.12-slim
# SANDBOX_TIMEOUT=10            # Sekunden
# SANDBOX_MEM_MB=256           # Speicherlimit

# Optional: Eskalations-Schwelle (0-10), darunter wird Cloud vorgeschlagen
# CONFIDENCE_THRESHOLD=6

# Optional: Autopilot -- bei Schwierigkeiten autonom ein staerkeres LOKALES
# Modell nutzen (true/false). Die Cloud bleibt immer einwilligungspflichtig.
# AUTO_LOCAL_UPGRADE=true
