{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Privacy-Agent",
  "version": "0.1.0",
  "identifier": "de.privacyagent.app",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Privacy-Agent",
        "width": 900,
        "height": 680,
        "minWidth": 520,
        "minHeight": 480
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:8765; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "dmg", "appimage", "deb"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ],
    "externalBin": ["binaries/privacy-agent-backend"]
  }
}
